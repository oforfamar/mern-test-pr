# Environment variables for Recipe Organizer

# Development
NODE_ENV=development

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/recipe_organizer?schema=public"

# For development, you can use a local PostgreSQL instance or a cloud service like:
# - Railway: https://railway.app/
# - Supabase: https://supabase.com/
# - PlanetScale: https://planetscale.com/
# - Neon: https://neon.tech/

# Example for local development:
# DATABASE_URL="postgresql://postgres:password@localhost:5432/recipe_organizer"

# API Keys (for future integrations)
# RECIPE_API_KEY=your_api_key

# Session Secret (for future authentication)
# SESSION_SECRET=your_session_secret

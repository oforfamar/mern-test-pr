# Environment variables for Recipe Organizer

# Development
NODE_ENV=development

# Database - MongoDB
DATABASE_URL="mongodb://username:password@localhost:27017/recipe_organizer?authSource=admin"

# For development, you can use a local MongoDB instance or a cloud service like:
# - MongoDB Atlas: https://www.mongodb.com/atlas
# - Railway: https://railway.app/
# - DigitalOcean: https://www.digitalocean.com/products/managed-databases-mongodb

# Example for local development:
# DATABASE_URL="mongodb://localhost:27017/recipe_organizer"

# Example for MongoDB Atlas:
# DATABASE_URL="mongodb+srv://username:password@cluster.mongodb.net/recipe_organizer?retryWrites=true&w=majority"

# API Keys (for future integrations)
# RECIPE_API_KEY=your_api_key

# Session Secret (for future authentication)
# SESSION_SECRET=your_session_secret
